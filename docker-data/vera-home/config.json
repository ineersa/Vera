{
  "local_mode": false,
  "backend": "api",
  "embedding_api": {
    "base_url": "http://host.docker.internal:8059/v1",
    "model_id": "coderankembed-q8_0.gguf"
  },
  "reranker_api": {
    "base_url": "http://host.docker.internal:8060/v1",
    "model_id": "bge-reranker-base-q8_0.gguf"
  },
  "completion_api": {
    "base_url": "http://host.docker.internal:8052/v1",
    "model_id": "flash",
    "timeout_secs": 120,
    "max_tokens": 16384,
    "max_alternatives": 4
  },
  "core_config": {
    "indexing": {
      "max_chunk_lines": 80,
      "default_excludes": [
        ".git",
        ".vera",
        "node_modules",
        "target",
        "build",
        "dist",
        "__pycache__",
        ".venv",
        ".github",
        "deptrac.yaml",
        "UPGRADE.md",
        "reference.php",
        "vendor"
      ],
      "max_file_size_bytes": 1000000,
      "extra_excludes": [],
      "no_ignore": false,
      "no_default_excludes": false,
      "max_chunk_bytes": 24576,
      "max_chunk_tokens": 0,
      "chunk_overlap_lines": 2
    },
    "retrieval": {
      "default_limit": 10,
      "rrf_k": 60.0,
      "rerank_candidates": 50,
      "reranking_enabled": true,
      "max_rerank_batch": 20,
      "max_output_chars": 12000,
      "reranker_max_docs_per_request": 8,
      "reranker_max_document_tokens": 300
    },
    "embedding": {
      "batch_size": 4,
      "max_concurrent_requests": 1,
      "timeout_secs": 60,
      "max_retries": 3,
      "max_stored_dim": 1024,
      "gpu_mem_limit_mb": 0,
      "low_vram": false
    }
  }
}
